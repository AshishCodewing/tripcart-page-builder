# Postgres connection string. pgvector extension must be available on this DB.
DATABASE_URL=

# Google AI Studio key — used for text-embedding-004 at ingest + retrieval.
# Get one at https://aistudio.google.com/apikey. Free tier is ~1500 req/day.
GOOGLE_API_KEY=

# Anthropic key — used by downstream consumers of retrieveDocs() that want a
# Claude-backed answer. Not required by the ingest script itself.
ANTHROPIC_API_KEY=
