// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum ContentStatus {
  DRAFT
  PUBLISHED
}

model Page {
  id          String        @id @default(cuid())
  slug        String
  path        String        @unique
  parentId    String?
  parent      Page?         @relation("PageTree", fields: [parentId], references: [id])
  children    Page[]        @relation("PageTree")
  title       String
  data        Json          @default("{}")
  status      ContentStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([parentId, slug])
  @@index([status])
  @@map("pages")
}

model Post {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  excerpt     String?
  data        Json          @default("{}")
  status      ContentStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  categories  Category[]    @relation("PostCategories")
  tags        Tag[]         @relation("PostTags")

  @@index([status, publishedAt])
  @@map("posts")
}

model Category {
  id    String @id @default(cuid())
  slug  String @unique
  name  String
  posts Post[] @relation("PostCategories")

  @@map("categories")
}

model Tag {
  id    String @id @default(cuid())
  slug  String @unique
  name  String
  posts Post[] @relation("PostTags")

  @@map("tags")
}

// Stub for post-MVP slug-rename redirects. Unused at MVP.
model Redirect {
  id        String   @id @default(cuid())
  fromPath  String   @unique
  toPath    String
  createdAt DateTime @default(now())

  @@map("redirects")
}

model DocChunk {
  id          String                       @id @default(cuid())
  contentHash String                       @unique
  content     String
  headerPath  String
  kind        String
  tokenCount  Int
  embedding   Unsupported("vector(3072)")
  createdAt   DateTime                     @default(now())

  urls DocChunkUrl[]

  @@map("doc_chunks")
}

model DocChunkUrl {
  id         String   @id @default(cuid())
  chunkHash  String
  url        String
  title      String
  lastSeenAt DateTime @default(now())

  chunk DocChunk @relation(fields: [chunkHash], references: [contentHash], onDelete: Cascade)

  @@unique([chunkHash, url])
  @@index([url])
  @@map("doc_chunk_urls")
}
